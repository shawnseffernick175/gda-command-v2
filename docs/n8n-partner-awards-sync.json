{
  "name": "Partner Awards Sync (USAspending)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 4 * * *" }]
        }
      },
      "name": "Cron 4AM EST",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "url": "https://api.usaspending.gov/api/v2/search/spending_by_award/",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Content-Type", "value": "application/json" }]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"filters\": {\n    \"recipient_search_text\": [\"71WX3\"],\n    \"time_period\": [{ \"start_date\": \"2024-01-01\", \"end_date\": \"{{ $now.toFormat('yyyy-MM-dd') }}\" }]\n  },\n  \"fields\": [\"Award ID\", \"Recipient Name\", \"Award Amount\", \"Start Date\", \"Awarding Agency\"],\n  \"limit\": 100\n}",
        "options": {}
      },
      "name": "Fetch Riverstone Awards (71WX3)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [470, 200]
    },
    {
      "parameters": {
        "url": "https://api.usaspending.gov/api/v2/search/spending_by_award/",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Content-Type", "value": "application/json" }]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"filters\": {\n    \"recipient_search_text\": [\"4V8V7\"],\n    \"time_period\": [{ \"start_date\": \"2024-01-01\", \"end_date\": \"{{ $now.toFormat('yyyy-MM-dd') }}\" }]\n  },\n  \"fields\": [\"Award ID\", \"Recipient Name\", \"Award Amount\", \"Start Date\", \"Awarding Agency\"],\n  \"limit\": 100\n}",
        "options": {}
      },
      "name": "Fetch PD Systems Awards (4V8V7)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [470, 400]
    },
    {
      "parameters": {
        "jsCode": "const rsResults = $('Fetch Riverstone Awards (71WX3)').all();\nconst pdResults = $('Fetch PD Systems Awards (4V8V7)').all();\n\nfunction mapAwards(results, partnerTag) {\n  const data = results[0]?.json?.results || [];\n  return data.map(a => ({\n    contract_id: a['Award ID'],\n    customer: a['Awarding Agency'],\n    value: parseFloat(a['Award Amount']) || null,\n    awarded_at: a['Start Date'] || null,\n    source: 'usaspending'\n  }));\n}\n\nconst rsAwards = mapAwards(rsResults, 'riverstone');\nconst pdAwards = mapAwards(pdResults, 'pd_systems');\n\nreturn [\n  { json: { partner_ou_tag: 'riverstone', awards: rsAwards } },\n  { json: { partner_ou_tag: 'pd_systems', awards: pdAwards } }\n];"
      },
      "name": "Map Awards",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [690, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.GDA_BACKEND_URL }}/api/partner-intel/awards/batch",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "x-gda-key", "value": "={{ $env.GDA_WEBHOOK_KEY }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "body", "value": "={{ JSON.stringify($json) }}" }
          ]
        },
        "options": {}
      },
      "name": "POST Batch Awards",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [910, 300]
    }
  ],
  "connections": {
    "Cron 4AM EST": {
      "main": [
        [
          { "node": "Fetch Riverstone Awards (71WX3)", "type": "main", "index": 0 },
          { "node": "Fetch PD Systems Awards (4V8V7)", "type": "main", "index": 0 }
        ]
      ]
    },
    "Fetch Riverstone Awards (71WX3)": { "main": [[{ "node": "Map Awards", "type": "main", "index": 0 }]] },
    "Fetch PD Systems Awards (4V8V7)": { "main": [[{ "node": "Map Awards", "type": "main", "index": 0 }]] },
    "Map Awards": { "main": [[{ "node": "POST Batch Awards", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
