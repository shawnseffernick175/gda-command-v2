{
  "name": "GDA.ingest.govtribe-cron",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 10 * * 1,4"
            }
          ]
        }
      },
      "id": "gt-cron",
      "name": "Mon + Thu 6am ET",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "path": "govtribe-cron-trigger",
        "responseMode": "lastNode",
        "options": {},
        "httpMethod": "POST"
      },
      "id": "gt-manual",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 500],
      "webhookId": "govtribe-cron-trigger"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.GDA_BASE_URL || 'http://localhost:3001' }}/api/ingest/govtribe/poll",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-gda-key",
              "value": "={{ $env.GDA_WEBHOOK_KEY || '' }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "gt-poll",
      "name": "GDA GovTribe Poll",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [500, 400],
      "credentials": {
        "httpHeaderAuth": {
          "id": "F4J3vYsPrJrYiO49",
          "name": "GDA Webhook Auth v2"
        }
      }
    }
  ],
  "connections": {
    "Mon + Thu 6am ET": {
      "main": [[{"node": "GDA GovTribe Poll", "type": "main", "index": 0}]]
    },
    "Manual Trigger": {
      "main": [[{"node": "GDA GovTribe Poll", "type": "main", "index": 0}]]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveDataErrorExecution": "all",
    "saveDataSuccessExecution": "all",
    "saveManualExecutions": true,
    "saveExecutionProgress": true,
    "callerPolicy": "workflowsFromSameOwner"
  }
}
