{
  "name": "GDA.launchpad.daily-refresh",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 6 * * *"
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Daily 6AM EST",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 300],
      "notes": "6:00 AM EST daily. Timezone set at workflow level."
    },
    {
      "parameters": {
        "url": "={{$env.GDA_BASE_URL}}/api/sentinel/run",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-gda-key",
              "value": "={{ $credentials.gdaWebhookAuthV2.apiKey }}"
            }
          ]
        },
        "options": {
          "timeout": 30000
        },
        "method": "POST"
      },
      "id": "kick-sentinel",
      "name": "Kick Sentinel",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [500, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "F4J3vYsPrJrYiO49",
          "name": "GDA Webhook Auth v2"
        }
      }
    },
    {
      "parameters": {
        "url": "={{$env.GDA_BASE_URL}}/api/launchpad/flags",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-gda-key",
              "value": "={{ $credentials.gdaWebhookAuthV2.apiKey }}"
            }
          ]
        },
        "options": {
          "timeout": 15000
        },
        "method": "GET"
      },
      "id": "warm-flags",
      "name": "Warm Launchpad Flags",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [750, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "F4J3vYsPrJrYiO49",
          "name": "GDA Webhook Auth v2"
        }
      }
    },
    {
      "parameters": {
        "url": "={{$env.GDA_BASE_URL}}/api/launchpad/daily-intel",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-gda-key",
              "value": "={{ $credentials.gdaWebhookAuthV2.apiKey }}"
            }
          ]
        },
        "options": {
          "timeout": 15000
        },
        "method": "GET"
      },
      "id": "warm-intel",
      "name": "Warm Daily Intel",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1000, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "F4J3vYsPrJrYiO49",
          "name": "GDA Webhook Auth v2"
        }
      }
    }
  ],
  "connections": {
    "Daily 6AM EST": {
      "main": [
        [
          {
            "node": "Kick Sentinel",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Kick Sentinel": {
      "main": [
        [
          {
            "node": "Warm Launchpad Flags",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Warm Launchpad Flags": {
      "main": [
        [
          {
            "node": "Warm Daily Intel",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "timezone": "America/New_York",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner"
  },
  "staticData": null,
  "tags": [
    {
      "name": "launchpad"
    },
    {
      "name": "daily"
    }
  ]
}
