        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst bodyKey = body.deploy_key;\nconst validKey = 'gda-deploy-2027-AWqjhbxDYNcyV1mr';\n\nif (bodyKey !== validKey) {\n  throw new Error('Unauthorized: Missing or invalid deploy_key');\n}\n\nreturn $input.all();"
