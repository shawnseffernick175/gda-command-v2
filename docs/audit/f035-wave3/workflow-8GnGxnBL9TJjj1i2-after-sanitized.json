    {
      "parameters": {
        "jsCode": "const item = $('Auth Guard').first().json;\nconst body = item.body || item;\nconst mode = body.mode || 'patch_script';\nconst msg = body.msg || 'deploy';\nlet script = '';\nif (mode === 'patch_script') {\n  const ps = body.patch_script;\n  if (!ps) throw new Error('patch_script is missing from body');\n  const b64 = Buffer.from(ps, 'utf-8').toString('base64');\n  script = 'echo ' + b64 + ' | base64 -d > /tmp/gda_patch.py && python3 /tmp/gda_patch.py && rm /tmp/gda_patch.py';\n} else if (mode === 'b64_file') {\n  const b64 = body.b64_content;\n  const dest = body.dest || '/opt/gda-command/src/App.jsx';\n  script = 'echo ' + b64 + ' | base64 -d > ' + dest + ' && echo WROTE: ' + dest;\n} else if (mode === 'build_only') {\n  script = 'echo WROTE: build_only_trigger';\n}\nreturn [{ json: { script, msg } }];"
      },
