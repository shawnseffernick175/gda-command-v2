    {
      "parameters": {
        "jsCode": "const buildOut = $('SSH Build').first().json.stdout || '';\nconst buildErr = $('SSH Build').first().json.stderr || '';\nconst isSuccess = buildOut.includes('DEPLOY_COMPLETE');\nconst deployMsg = $('Build Script').first().json.msg || 'deploy';\n\n// Extract git commit short hash\nconst commitMatch = buildOut.match(/\\[main ([a-f0-9]+)\\]/);\nconst headCommit = commitMatch ? commitMatch[1] : 'unknown';\n\n// Extract line count from wc -l output\nconst lineMatch = buildOut.match(/(\\d+)\\s+\\/opt\\/gda-command/);\nconst lineCount = lineMatch ? lineMatch[1] : 'N/A';\n\n// Extract deploy count from timestamp in DEPLOY_COMPLETE_<epoch>\nconst tsMatch = buildOut.match(/DEPLOY_COMPLETE_(\\d+)/);\nconst deployTs = tsMatch ? tsMatch[1] : String(Math.floor(Date.now()/1000));\n\nconst statusLine = isSuccess\n  ? `\u2705 Deploy succeeded: ${deployMsg}`\n  : `\u274c Deploy failed: ${deployMsg}`;\n\nconst brokenSection = isSuccess\n  ? 'None'\n  : (buildErr || buildOut).slice(-600);\n\nreturn [{ json: {\n  session: new Date().toISOString().replace('T', ' ').substring(0, 19) + ' UTC',\n  completed: statusLine,\n  broken: brokenSection,\n  next_steps: isSuccess ? 'Monitor live dashboard' : 'Investigate build output above',\n  head_commit: headCommit,\n  line_count: lineCount,\n  deploy_count: deployTs\n} }];"
      },
