        "query": "SELECT\n  COUNT(*) as opp_count,\n  ROUND(COALESCE(SUM(estimated_value::numeric),0)/1000000,1) as pipeline_m,\n  NOW() as db_checked_at\nFROM gda_opportunity_tracker\nWHERE stage NOT IN ('No-Go','No-Bid','Cancelled','Lost','Won');",
