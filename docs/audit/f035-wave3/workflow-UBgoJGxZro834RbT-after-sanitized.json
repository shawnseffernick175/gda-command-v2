    {
      "parameters": {
        "method": "POST",
        "url": "https://n8n.csr-llc.tech/webhook/gda-grep-appjsx",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-gda-key",
              "value": "={{ $env.GDA_WEBHOOK_HEADER_VALUE_V2 }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"cmd\": \"df -h / | tail -1 | awk '{print $5}' && free -m | awk 'NR==2{printf \\\"%s/%s MB\\\\n\\\", $3, $2}' && uptime | awk -F'load average:' '{print $2}'\"}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "ph-vps",
      "name": "VPS Metrics",
      "position": [
        864,
        480
      ],
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "let db = {}; let vps = {};\ntry { db = $('DB Health Check').first().json || {}; } catch(e) {}\ntry { const r = $('VPS Metrics').first().json; vps = typeof r === 'string' ? {raw: r} : (r || {}); } catch(e) {}\n\nlet disk_used = 'N/A', mem_used = 'N/A', load_avg = 'N/A';\ntry {\n  const lines = (vps.content || vps.stdout || '').trim().split('\\n');\n  if (lines[0]) disk_used = lines[0].trim();\n  if (lines[1]) mem_used = lines[1].trim();\n  if (lines[2]) load_avg = lines[2].trim();\n} catch(e) {}\n\nconst health = {\n  status: 'ok',\n  checked_at: new Date().toISOString(),\n  platform: {\n    opportunities: parseInt(db.opp_count) || 0,\n    pursuing: parseInt(db.opp_count) || 0,\n    capture_plans: 0,\n    active_contracts: 0,\n    pipeline_value_m: parseFloat(db.pipeline_m) || 0\n  },\n  activity: {\n    intel_items_24h: 0,\n    briefings_24h: 0,\n    last_briefing: null,\n    last_intel: null\n  },\n  infrastructure: {\n    disk_used_pct: disk_used,\n    memory_used: mem_used,\n    load_average: load_avg,\n    vps: '187.77.206.105',\n    n8n_version: '2.37.1'\n  },\n  signals: {\n    db_online: !!db.db_checked_at,\n    briefing_current: false,\n    intel_flowing: false\n  }\n};\n\nreturn [{json: health}];"
      },
