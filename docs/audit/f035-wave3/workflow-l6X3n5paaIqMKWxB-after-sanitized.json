      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nif (!rows.length) {\n  return [{ json: { status: 'error', error: { code: 'NOT_FOUND', message: 'Signal not found' } } }];\n}\nreturn [{ json: { status: 'ok', action: 'get', data: rows[0], meta: { generatedAt: new Date().toISOString() } } }];"
