      ],
      "parameters": {
        "jsCode": "const body=$input.first().json.body||{};\nif(body.auth_key!==$env.GDA_WEBHOOK_HEADER_VALUE_V2) return [{json:{error:'Unauthorized'}}];\nreturn [{json:{action:body.action||'list'}}];"
