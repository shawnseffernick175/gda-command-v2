    {
      "id": "pl03",
      "name": "Query",
      "type": "n8n-nodes-base.postgres",
      "position": [
        640,
        300
      ],
      "parameters": {
        "query": "SELECT id, opp_title, agency, dept, naics_code, set_aside, estimated_value, gda_score, gda_label, stage, response_deadline, source_url, place_of_performance, ai_analysis, incumbent_analysis FROM gda_opportunity_tracker WHERE gda_label IN ('PURSUE','EVALUATE','MONITOR') ORDER BY gda_score DESC LIMIT 100;",
        "options": {},
        "operation": "executeQuery"
      },
      "credentials": {
        "postgres": {
          "id": "HwronxMmGY5XDGEt",
          "name": "GDA Postgres"
        }
      },
      "typeVersion": 2.6
    },
    {
      "id": "pl04",
      "name": "Format",
      "type": "n8n-nodes-base.code",
      "position": [
        860,
        300
      ],
      "parameters": {
        "jsCode": "const rows=$input.all().map(i=>i.json);\nreturn [{json:{status:'ok',count:rows.length,pipeline:rows}}];"
      },
      "typeVersion": 2
    }
