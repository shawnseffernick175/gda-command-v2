  "nodes": [
    {
      "id": "pwin-sched",
      "name": "Daily 6am ET",
      "parameters": {
        "rule": {
          "interval": [
            {
              "expression": "0 6 * * *",
              "field": "cronExpression"
            }
          ]
        },
        "timezone": "America/New_York"
      },
      "position": [
        200,
        300
      ],
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2
    },
    {
      "continueOnFail": true,
      "credentials": {
        "postgres": {
          "id": "HwronxMmGY5XDGEt",
          "name": "GDA Postgres"
        }
      },
      "id": "pwin-fetch-opps",
      "name": "Fetch Unscored PURSUE Opps",
      "parameters": {
        "operation": "executeQuery",
        "options": {},
        "query": "SELECT id, opp_title as opportunity_name, agency, estimated_value, stage, gda_label FROM gda_opportunity_tracker WHERE gda_label = 'PURSUE' AND stage NOT IN ('No-Bid','Cancelled','No-Go','Lost','Won') AND (gda_score IS NULL OR gda_score = 0) ORDER BY id ASC LIMIT 20"
      },
      "position": [
        420,
        300
      ],
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5
    },
    {
      "id": "pwin-check-any",
      "name": "Any Unscored?",
      "parameters": {
        "conditions": {
          "combinator": "and",
          "conditions": [
            {
              "id": "has-rows",
              "leftValue": "={{ $input.all().length }}",
              "operator": {
                "operation": "gt",
                "type": "number"
              },
              "rightValue": 0
            }
          ],
          "options": {}
        },
        "options": {}
      },
      "position": [
        640,
        300
      ],
      "type": "n8n-nodes-base.if",
      "typeVersion": 2
    },
    {
      "continueOnFail": true,
      "id": "pwin-batch-call",
      "name": "Batch Score Opps",
      "parameters": {
        "jsCode": "const opps = $input.all().map(i => i.json);\nconst results = [];\nconst key = $env.GDA_WEBHOOK_HEADER_VALUE_V2;\n\nfor (const opp of opps) {\n  try {\n    const resp = await fetch('https://n8n.csr-llc.tech/webhook/gda-pwin-calculator', {\n      method: 'POST',\n      headers: { 'x-gda-key': key, 'Content-Type': 'application/json' },\n      body: JSON.stringify({ action: 'calculate', opp_id: opp.id, opportunity_name: opp.opportunity_name, agency: opp.agency, value: opp.estimated_value, stage: opp.stage })\n    });\n    const data = await resp.json();\n    results.push({ opp_id: opp.id, opp_name: opp.opportunity_name, agency: opp.agency, value: opp.estimated_value, pwin: data.pwin || data.score || data.gda_score || null, status: 'scored' });\n  } catch(e) {\n    results.push({ opp_id: opp.id, opp_name: opp.opportunity_name, status: 'error', error: e.message });\n  }\n}\n\nreturn [{ json: { results, scored: results.filter(r=>r.status==='scored').length, errors: results.filter(r=>r.status==='error').length } }];"
      },
      "position": [
        860,
        200
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "continueOnFail": true,
      "id": "pwin-telegram",
      "name": "Telegram Pwin Summary",
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst results = data.results || [];\nconst scored = data.scored || 0;\nconst errors = data.errors || 0;\nconst lines = results.filter(r => r.status === 'scored' && r.pwin !== null).map(r => `  OPP-${r.opp_id} | ${(r.opp_name||'').substring(0,30)} | pWin: ${r.pwin}%`).join('\\n');\nconst msg = `DAILY PWIN LOOP\\n${new Date().toISOString().split('T')[0]}\\n\\nScored: ${scored} | Errors: ${errors}\\n\\n${lines || 'No new scores today'}\\n\\nhttps://gda.csr-llc.tech`;\nreturn [{ json: { chat_id: 8631035943, message: msg } }];"
      },
      "position": [
        1080,
        200
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "continueOnFail": true,
      "id": "pwin-tg-send",
      "name": "Send Telegram",
      "parameters": {
        "body": "={{ JSON.stringify($json) }}",
        "contentType": "raw",
        "headerParameters": {
          "parameters": [
            {
              "name": "x-gda-key",
              "value": "={{ $env.GDA_WEBHOOK_HEADER_VALUE_V2 }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "method": "POST",
        "options": {},
        "rawContentType": "application/json",
        "sendBody": true,
        "sendHeaders": true,
        "url": "https://n8n.csr-llc.tech/webhook/gda-notify"
      },
      "position": [
        1300,
        200
      ],
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2
    },
    {
      "id": "pwin-no-action",
      "name": "No Unscored Opps",
      "parameters": {
        "jsCode": "return [{ json: { message: 'No unscored PURSUE opps today' } }];"
      },
      "position": [
        860,
        400
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    }
  ],
