# gda-agent-v3 environment variables
# Copy to .env and fill in values

# --- Model providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Database ---
# Read-write connection (for audit tables: agent_runs, agent_tool_calls)
AGENT_DB_URL=postgresql://gda_staging:password@postgres-staging:5432/gda_staging
# Read-only connection (for db_query tool — enforced via gda_agent_ro role)
AGENT_DB_RO_URL=postgresql://gda_agent_ro:agent_ro_default@postgres-staging:5432/gda_staging

# --- Auth ---
# Shared service token (backend-v3 uses this to authenticate requests)
AGENT_SERVICE_TOKEN=

# --- External API keys ---
SAM_GOV_API_KEY=
PERPLEXITY_API_KEY=
TAVILY_API_KEY=

# --- Internal services ---
BACKEND_V3_URL=http://gda-backend-v3:4000

# --- Agent configuration ---
AGENT_DEFAULT_MODEL=openai:gpt-4o
AGENT_MAX_STEPS=12
AGENT_WALL_TIMEOUT_S=30
AGENT_HOURLY_COST_LIMIT_USD=5

# --- GovWin IQ connector ---
GOVWIN_USERNAME=
GOVWIN_PASSWORD=
GOVWIN_CLIENT_ID=
GOVWIN_CLIENT_SECRET=
