{
  "name": "@gda/backend-v3",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/analysis.js",
    "lint": "eslint src/ tests/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/lib/migrate.ts",
    "db:migrate:dry-run": "tsx src/lib/migrate.ts --dry-run",
    "migrate:legacy:dry-run": "tsx src/migration/run.ts",
    "migrate:legacy:commit": "tsx src/migration/run.ts --commit",
    "migrate:legacy:entity": "tsx src/migration/run.ts --entity",
    "migrate:legacy:report": "tsx src/migration/run.ts --report-only",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "audit:schema": "tsx tests/audit-schema.ts",
    "backfill:unified": "tsx src/scripts/backfill-unified-opportunities.ts",
    "backfill:validate-opps": "tsx src/scripts/backfill_validate_existing_opps.ts",
    "backfill:incumbent": "tsx src/scripts/backfill_incumbent.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.8.0",
    "fastify": "^5.2.1",
    "fuzzball": "^2.2.6",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "node-cron": "^4.2.1",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.10",
    "openai": "^6.42.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.5",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "undici": "^7.26.0",
    "uuid": "^11.1.0",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.1",
    "@types/adm-zip": "^0.5.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "testcontainers": "^12.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
