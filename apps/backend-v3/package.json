{
  "name": "@gda/backend-v3",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/analysis.js",
    "lint": "eslint src/ tests/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:dry-run": "tsx src/migration/run.ts",
    "migrate:commit": "tsx src/migration/run.ts --commit",
    "migrate:entity": "tsx src/migration/run.ts --entity",
    "migrate:report": "tsx src/migration/run.ts --report-only"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@fastify/static": "^8.1.0",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.5",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "uuid": "^11.1.0",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.2",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
