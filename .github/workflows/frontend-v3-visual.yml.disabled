# Frontend V3 Visual Regression — Playwright snapshot comparison
#
# Draft workflow (F-215-D5). Disabled until F-218 enables it by removing .disabled extension.
# Posts before/after/diff images to PR. Baseline updates gated by viz-baseline-update label.

name: Frontend V3 Visual Regression

on:
  pull_request:
    paths:
      - 'packages/frontend-v3/**'
      - '.github/workflows/frontend-v3-visual.yml'

permissions:
  contents: read
  pull-requests: write

jobs:
  visual-regression:
    name: Visual Regression
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5

      - uses: actions/setup-node@v5
        with:
          node-version: 22
          cache: npm

      - run: npm ci
      - run: npm run build -w packages/shared

      - name: Install Playwright browsers
        run: npx playwright install --with-deps chromium

      - name: Build frontend-v3 for visual tests
        working-directory: packages/frontend-v3
        run: npx vite build

      - name: Run visual regression tests
        working-directory: packages/frontend-v3
        id: visual-test
        env:
          MOCK_LLM: '1'
        run: |
          npx playwright test --config playwright.visual.config.ts 2>&1 | tee /tmp/visual-output.txt
          echo "exit_code=${PIPESTATUS[0]}" >> "$GITHUB_OUTPUT"

      - name: Collect diff images
        if: always()
        id: collect-diffs
        working-directory: packages/frontend-v3
        run: |
          DIFF_DIR="test-results/visual-diffs"
          if [ -d "$DIFF_DIR" ] && [ "$(ls -A "$DIFF_DIR" 2>/dev/null)" ]; then
            echo "has_diffs=true" >> "$GITHUB_OUTPUT"
          else
            echo "has_diffs=false" >> "$GITHUB_OUTPUT"
          fi

      - name: Upload diff artifacts
        if: always() && steps.collect-diffs.outputs.has_diffs == 'true'
        uses: actions/upload-artifact@v4
        with:
          name: visual-regression-diffs
          path: packages/frontend-v3/test-results/visual-diffs/
          retention-days: 30

      - name: Post diff images to PR
        if: always() && github.event_name == 'pull_request'
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            let body = '## Frontend V3 Visual Regression\n\n';

            const hasDiffs = '${{ steps.collect-diffs.outputs.has_diffs }}' === 'true';
            const exitCode = '${{ steps.visual-test.outputs.exit_code }}';

            if (exitCode === '0') {
              body += 'All visual snapshots match baselines. No regressions detected.\n';
            } else if (hasDiffs) {
              body += '**Visual differences detected.** Review the diff artifacts attached to this workflow run.\n\n';
              body += 'To approve these changes, add the `viz-baseline-update` label to this PR.\n';
            } else {
              body += 'Visual test failed. Check the workflow logs for details.\n';
            }

            const { data: comments } = await github.rest.issues.listComments({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.issue.number,
            });
            const existing = comments.find(c =>
              c.user.type === 'Bot' && c.body.includes('Frontend V3 Visual Regression')
            );
            if (existing) {
              await github.rest.issues.updateComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                comment_id: existing.id,
                body,
              });
            } else {
              await github.rest.issues.createComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                issue_number: context.issue.number,
                body,
              });
            }

      - name: Gate on viz-baseline-update label
        if: steps.collect-diffs.outputs.has_diffs == 'true'
        uses: actions/github-script@v7
        with:
          script: |
            const { data: pr } = await github.rest.pulls.get({
              owner: context.repo.owner,
              repo: context.repo.repo,
              pull_number: context.issue.number,
            });
            const hasLabel = pr.labels.some(l => l.name === 'viz-baseline-update');
            if (!hasLabel) {
              core.setFailed(
                'Visual diffs detected but PR does not have the "viz-baseline-update" label. ' +
                'Add the label to approve baseline updates, or fix the visual regression.'
              );
            }
