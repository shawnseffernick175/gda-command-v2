{
  "name": "@gda/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc -b ../shared && tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:migrations": "vitest run --config vitest.migration.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/reset.ts",
    "db:backup": "../../scripts/backup.sh",
    "db:restore": "../../scripts/restore.sh",
    "db:backup-status": "../../scripts/backup-status.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@gda/shared": "*",
    "@kenjiuno/msgreader": "^1.28.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "file-type": "^22.0.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.8",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "node-html-parser": "^7.1.0",
    "nodemailer": "^8.0.7",
    "officeparser": "^5.1.1",
    "openai": "^6.37.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/js-yaml": "^4.0.9",
    "@types/mailparser": "^3.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
