# GDA Gateway v2 — Environment Configuration
# Copy to .env and fill in values.

# Server
PORT=3001

# n8n Webhook Integration (for QA health checks and dry-run)
# Base URL of your n8n instance (no trailing slash)
N8N_BASE_URL=https://n8n.csr-llc.tech
# Optional webhook auth key (sent as x-gda-key header)
GDA_WEBHOOK_KEY=

# n8n REST API (for failed executions, workflow registry)
# Usually: https://n8n.csr-llc.tech/api/v1
N8N_API_BASE=https://n8n.csr-llc.tech/api/v1
N8N_API_KEY=

# Postgres (for opportunities, doctrine, etc.)
# DATABASE_URL=postgresql://user:password@localhost:5432/gda_command

# QA check timeout in ms (default: 15000)
# QA_CHECK_TIMEOUT_MS=15000
