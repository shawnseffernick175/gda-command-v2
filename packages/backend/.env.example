# GDA Gateway v2 — Environment Configuration
# Copy to .env and fill in values.

# Server
PORT=3001

# n8n Webhook Integration (for QA health checks and dry-run)
# Base URL of your n8n instance (no trailing slash)
N8N_BASE_URL=https://n8n.csr-llc.tech
# Optional webhook auth key (sent as x-gda-key header)
GDA_WEBHOOK_KEY=

# n8n REST API (for failed executions, workflow registry)
# Usually: https://n8n.csr-llc.tech/api/v1
N8N_API_BASE=https://n8n.csr-llc.tech/api/v1
N8N_API_KEY=

# Postgres (for opportunities, doctrine, etc.)
# Run `docker compose up -d` from repo root to start local Postgres.
DATABASE_URL=postgresql://gda:gda_dev_password@localhost:5432/gda_command

# Auth
# Set to "true" in production to require JWT auth on all API routes.
# Default (false): dev mode, all requests pass through as admin.
AUTH_REQUIRED=false
JWT_SECRET=gda-dev-secret-change-in-production

# OpenAI LLM Integration
# Required for AI features: RAG chat, CPARS narrative generation,
# RFP shredding, color review AI. Falls back to mock when not set.
OPENAI_API_KEY=

# SAM.gov API Integration
# Required for live federal contract opportunity feeds.
# Get your key: https://sam.gov → Account Details → API Key
SAM_API_KEY=

# Feed Sync Interval (hours, default: 6)
# Set to 0 to disable automatic sync.
FEED_SYNC_INTERVAL_HOURS=6

# SMTP Email Notifications
# Required for email notification delivery.
# Supports any SMTP provider (Gmail, SendGrid, AWS SES, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GDA Command <noreply@yourdomain.com>

# App URL (used in email links, default: https://gda.csr-llc.tech)
APP_URL=https://gda.csr-llc.tech

# QA check timeout in ms (default: 15000)
# QA_CHECK_TIMEOUT_MS=15000
