{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$version": "1.0.0",
  "$description": "GDA Command V3 Design Tokens — D2 Spec. Consumed by F-218 Tailwind v4 integration.",

  "color": {
    "dark": {
      "canvas": { "$value": "#0B0D0F", "$description": "Page background, app shell" },
      "surface": { "$value": "#13161A", "$description": "Card backgrounds, panels" },
      "surface-raised": { "$value": "#1A1E23", "$description": "Modals, drawers, tooltips, popovers" },
      "border": { "$value": "#2A2F36", "$description": "Default dividers, card borders" },
      "border-strong": { "$value": "#3D434C", "$description": "Focused inputs, active borders, reference lines" },
      "ink-primary": { "$value": "#E6E8EB", "$description": "Primary text, headings, labels" },
      "ink-muted": { "$value": "#9AA0A8", "$description": "Secondary text, captions, axis labels" },
      "ink-dim": { "$value": "#6B7079", "$description": "Disabled text, placeholder text" },
      "accent": { "$value": "#01696F", "$description": "Hydra Teal — links, primary buttons, active states" },
      "accent-hover": { "$value": "#017F86", "$description": "Hover on accent elements" },
      "accent-pressed": { "$value": "#015C61", "$description": "Active/pressed accent elements" },
      "critical": { "$value": "#A12C7B", "$description": "Deep magenta — severity only" },
      "critical-hover": { "$value": "#B8338E", "$description": "Hover on critical elements" },
      "success": { "$value": "#3FA66B", "$description": "Positive outcomes, compliant status" },
      "success-hover": { "$value": "#4DBD7A", "$description": "Hover on success elements" },
      "warning": { "$value": "#C48A1E", "$description": "Expiring certs, approaching deadlines" },
      "warning-hover": { "$value": "#D69B2F", "$description": "Hover on warning elements" }
    },
    "light": {
      "canvas": { "$value": "#F7F6F2", "$description": "Warm off-white page background" },
      "surface": { "$value": "#FFFFFF", "$description": "Card backgrounds" },
      "surface-raised": { "$value": "#FFFFFF", "$description": "Modals, drawers, tooltips" },
      "border": { "$value": "#D4D1CA", "$description": "Hairline borders, dividers" },
      "border-strong": { "$value": "#B8B5AE", "$description": "Focused inputs, active borders" },
      "ink-primary": { "$value": "#28251D", "$description": "Primary text" },
      "ink-muted": { "$value": "#7A7974", "$description": "Secondary text, captions" },
      "ink-dim": { "$value": "#A3A09A", "$description": "Disabled text, placeholder text" },
      "accent": { "$value": "#01696F", "$description": "Hydra Teal — same across themes" },
      "accent-hover": { "$value": "#017F86", "$description": "Hover on accent elements" },
      "accent-pressed": { "$value": "#015C61", "$description": "Active/pressed accent elements" },
      "critical": { "$value": "#A12C7B", "$description": "Deep magenta — same across themes" },
      "critical-hover": { "$value": "#B8338E", "$description": "Hover on critical elements" },
      "success": { "$value": "#2E8B57", "$description": "Positive outcomes" },
      "success-hover": { "$value": "#3A9D66", "$description": "Hover on success elements" },
      "warning": { "$value": "#B45309", "$description": "Amber warnings" },
      "warning-hover": { "$value": "#C5641A", "$description": "Hover on warning elements" }
    },
    "semantic": {
      "bg-canvas": { "$value": "{color.dark.canvas}", "$description": "Root app background" },
      "bg-surface": { "$value": "{color.dark.surface}", "$description": "Card / panel fill" },
      "bg-surface-raised": { "$value": "{color.dark.surface-raised}", "$description": "Elevated containers" },
      "text-primary": { "$value": "{color.dark.ink-primary}", "$description": "Body text, headings" },
      "text-secondary": { "$value": "{color.dark.ink-muted}", "$description": "Captions, labels" },
      "text-disabled": { "$value": "{color.dark.ink-dim}", "$description": "Disabled, placeholder" },
      "border-default": { "$value": "{color.dark.border}", "$description": "Standard borders" },
      "border-focused": { "$value": "{color.dark.border-strong}", "$description": "Focus rings, active" },
      "accent-fg": { "$value": "{color.dark.accent}", "$description": "Accent text/icons" },
      "accent-bg": { "$value": "{color.dark.accent}", "$description": "Primary button fill" },
      "accent-bg-hover": { "$value": "{color.dark.accent-hover}", "$description": "Primary button hover" },
      "accent-bg-pressed": { "$value": "{color.dark.accent-pressed}", "$description": "Primary button pressed" },
      "state-critical": { "$value": "{color.dark.critical}", "$description": "Critical badges, flags" },
      "state-critical-hover": { "$value": "{color.dark.critical-hover}", "$description": "Critical hover" },
      "state-success": { "$value": "{color.dark.success}", "$description": "Success indicators" },
      "state-success-hover": { "$value": "{color.dark.success-hover}", "$description": "Success hover" },
      "state-warning": { "$value": "{color.dark.warning}", "$description": "Warning badges" },
      "state-warning-hover": { "$value": "{color.dark.warning-hover}", "$description": "Warning hover" },
      "state-info": { "$value": "{color.dark.accent}", "$description": "Informational indicators" }
    },
    "stage": {
      "0": { "$value": "#6B7079", "$description": "Long Term Positioning" },
      "1": { "$value": "#9AA0A8", "$description": "Opportunity Assessment" },
      "2": { "$value": "#01696F", "$description": "Capture Planning" },
      "3": { "$value": "#01696F", "$description": "Proposal Planning" },
      "4": { "$value": "#C48A1E", "$description": "Proposal Development" },
      "5": { "$value": "#C48A1E", "$description": "Post-Submittal" },
      "6": { "$value": "#3FA66B", "$description": "Post-Award" }
    }
  },

  "space": {
    "0": { "$value": "0px" },
    "0.5": { "$value": "2px", "$description": "Hairline gaps" },
    "1": { "$value": "4px", "$description": "Micro-grid: inline icon gaps, chip padding-y" },
    "2": { "$value": "8px", "$description": "Base grid unit: input padding, small gaps" },
    "3": { "$value": "12px", "$description": "Medium internal padding" },
    "4": { "$value": "16px", "$description": "Standard gap between elements" },
    "5": { "$value": "20px", "$description": "Medium section spacing" },
    "6": { "$value": "24px", "$description": "Card internal padding" },
    "8": { "$value": "32px", "$description": "Page horizontal padding, section gaps" },
    "10": { "$value": "40px", "$description": "Large section spacing" },
    "12": { "$value": "48px", "$description": "Major vertical separation" },
    "16": { "$value": "64px", "$description": "Page-level vertical sections" }
  },

  "radius": {
    "sm": { "$value": "4px", "$description": "Inputs, buttons, badges" },
    "md": { "$value": "6px", "$description": "Cards, panels, modals" },
    "full": { "$value": "999px", "$description": "Chips, tags, pills" }
  },

  "fontSize": {
    "xs": { "$value": "0.75rem", "$description": "Badges, micro-labels" },
    "sm": { "$value": "0.8125rem", "$description": "Default UI text, table cells" },
    "base": { "$value": "0.875rem", "$description": "Body paragraphs" },
    "md": { "$value": "1rem", "$description": "Section sub-headers, card titles" },
    "lg": { "$value": "1.125rem", "$description": "Section headers" },
    "xl": { "$value": "1.25rem", "$description": "Page sub-titles" },
    "2xl": { "$value": "1.5rem", "$description": "Page titles" },
    "3xl": { "$value": "1.875rem", "$description": "Display headings" }
  },

  "lineHeight": {
    "xs": { "$value": "1.0" },
    "sm": { "$value": "1.25" },
    "base": { "$value": "1.375" },
    "md": { "$value": "1.5" },
    "lg": { "$value": "1.5" },
    "xl": { "$value": "1.5" },
    "2xl": { "$value": "1.375" },
    "3xl": { "$value": "1.25" }
  },

  "fontFamily": {
    "ui": { "$value": "'Inter', system-ui, -apple-system, sans-serif", "$description": "All UI text" },
    "numeric": { "$value": "'Inter', system-ui, sans-serif", "$description": "Tabular numbers with font-feature-settings: 'tnum', 'ss01'" },
    "mono": { "$value": "'JetBrains Mono', ui-monospace, monospace", "$description": "Solicitation IDs, notice numbers, code blocks" }
  },

  "fontWeight": {
    "regular": { "$value": 400 },
    "medium": { "$value": 500 },
    "semibold": { "$value": 600 },
    "bold": { "$value": 700 }
  },

  "motion": {
    "reveal": { "$value": "120ms", "$description": "Panel open, content appear", "easing": "ease-out" },
    "state": { "$value": "80ms", "$description": "Button state, toggle, checkbox", "easing": "ease-out" },
    "hover": { "$value": "0ms", "$description": "Hover color changes — instant" }
  },

  "borderWidth": {
    "default": { "$value": "1px", "$description": "Standard borders" },
    "focused": { "$value": "1.5px", "$description": "Focus rings, active states" }
  },

  "elevation": {
    "$description": "Zero shadows. Elevation via surface color + border only.",
    "base": { "background": "{color.semantic.bg-canvas}", "border": "none" },
    "raised": { "background": "{color.semantic.bg-surface}", "border": "1px solid {color.semantic.border-default}" },
    "overlay": { "background": "{color.semantic.bg-surface-raised}", "border": "1px solid {color.semantic.border-default}" }
  }
}
