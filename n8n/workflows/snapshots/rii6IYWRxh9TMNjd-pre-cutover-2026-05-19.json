    {
      "id": "auth1",
      "name": "Auth Guard",
      "type": "n8n-nodes-base.code",
      "position": [
        220,
        200
      ],
      "parameters": {
        "jsCode": "if (!$env.GDA_API_KEY_2026 || !$env.GDA_DEPLOY_KEY_2026 || !$env.GDA_WEBHOOK_SECRET_2026) throw new Error('2026 auth env vars not set');\nconst headers = $input.first().json.headers || {};\nconst body = $input.first().json.body || {};\nconst auth = headers[\"x-gda-auth\"] || headers[\"x-gda-key\"] || body.auth_key || body.deploy_key || \"\";\nconst validKeys = [$env.GDA_DEPLOY_KEY_2026, $env.GDA_API_KEY_2026, $env.GDA_WEBHOOK_SECRET_2026];\nif (!validKeys.includes(auth)) {\n  const origin = (headers.origin || headers.referer || \"\").toLowerCase();\n  const trusted = [\"gda.csr-llc.tech\",\"n8n.csr-llc.tech\",\"localhost\",\"gdacommand.retool.com\"];\n  if (!trusted.some(o => origin.includes(o))) throw new Error(\"Unauthorized\");\n}\nreturn [{ json: body }];"
      },
      "typeVersion": 2
    },
    {
      "id": "validate1",
      "name": "Validate Query",
      "type": "n8n-nodes-base.code",
      "position": [
        440,
        200
      ],
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst query = body.query || body.question || body.message;\nconst top_k = body.top_k || 5;\nif (!query) { throw new Error('query is required'); }\nreturn [{ json: { query, top_k } }];"
      },
      "typeVersion": 2
    },
    {
      "id": "embed1",
      "name": "Embed Query",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        660,
        200
      ],
      "parameters": {
        "url": "https://api.openai.com/v1/embeddings",
        "method": "POST",
        "options": {},
        "jsonBody": "={{ JSON.stringify({ model: 'text-embedding-3-small', input: $json.query }) }}",
        "sendBody": true,
        "specifyBody": "json",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi"
      },
      "credentials": {
        "openAiApi": {
          "id": "unLYjAN4H9MFrJ0u",
          "name": "OpenAi account"
        }
      },
      "typeVersion": 4.2
    },
    {
      "id": "pinecone1",
      "name": "Query Pinecone",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        880,
        200
      ],
      "parameters": {
        "url": "https://ai-assistant-ezysp85.svc.aped-4627-b74a.pinecone.io/query",
        "method": "POST",
        "options": {},
        "jsonBody": "={{ JSON.stringify({ namespace: 'gda-documents', topK: $('Validate Query').first().json.top_k, vector: $json.data[0].embedding, includeMetadata: true }) }}",
        "sendBody": true,
        "specifyBody": "json",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "pineconeApi"
      },
      "credentials": {
        "pineconeApi": {
          "id": "cVqyKm27Ws9a1NJG",
          "name": "PineconeApi account"
        }
      },
      "typeVersion": 4.2
    },
    {
      "id": "format1",
      "name": "Build Context",
      "type": "n8n-nodes-base.code",
      "position": [
        1100,
        200
      ],
      "parameters": {
        "jsCode": "const query = $('Validate Query').first().json.query;\nconst matches = $json.matches || [];\nif (matches.length === 0) {\n  return [{ json: { query, context: '', sources: [], has_results: false } }];\n}\nconst sources = [];\nconst chunks = [];\nfor (const m of matches) {\n  const meta = m.metadata || {};\n  chunks.push(meta.text || '');\n  if (meta.document_id && !sources.includes(meta.document_id)) sources.push(meta.document_id);\n}\nreturn [{ json: { query, context: chunks.join('\\n\\n---\\n\\n'), sources, has_results: true } }];"
      },
      "typeVersion": 2
    },
    {
      "id": "ai1",
      "name": "Ask Claude",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1320,
        200
      ],
      "parameters": {
        "url": "https://api.anthropic.com/v1/messages",
        "method": "POST",
        "options": {},
        "jsonBody": "={{ JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 1024, messages: [{ role: 'user', content: $json.has_results ? 'Based on these documents:\\n\\n' + $json.context + '\\n\\nAnswer this question: ' + $json.query + '\\n\\nRespond as JSON: {\"answer\": \"...\", \"sources\": [...], \"confidence\": \"high|medium|low\"}' : 'No documents found for: ' + $json.query + '\\n\\nRespond as JSON: {\"answer\": \"No relevant documents found in the knowledge base.\", \"sources\": [], \"confidence\": \"low\"}' }] }) }}",
        "sendBody": true,
        "sendHeaders": true,
        "specifyBody": "json",
        "authentication": "predefinedCredentialType",
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            }
          ]
        },
        "nodeCredentialType": "anthropicApi"
      },
      "credentials": {
        "anthropicApi": {
          "id": "d92MU0tRK7bEGV83",
          "name": "Anthropic account"
        }
      },
      "typeVersion": 4.2
    },
    {
      "id": "format2",
      "name": "Format Response",
      "type": "n8n-nodes-base.code",
      "position": [
        1540,
        200
      ],
      "parameters": {
        "jsCode": "const query = $('Validate Query').first().json.query;\nconst sources = $('Build Context').first().json.sources;\nconst raw = $json.content?.[0]?.text || $json.content || '';\nlet parsed = {};\ntry {\n  const match = typeof raw === 'string' ? raw.match(/\\{[\\s\\S]*\\}/) : null;\n  if (match) parsed = JSON.parse(match[0]);\n  else parsed = { answer: typeof raw === 'string' ? raw : JSON.stringify(raw) };\n} catch(e) {\n  parsed = { answer: typeof raw === 'string' ? raw : JSON.stringify(raw) };\n}\nreturn [{ json: {\n  answer: parsed.answer || 'No answer generated',\n  sources: parsed.sources || sources,\n  confidence: parsed.confidence || 'medium',\n  query,\n  timestamp: new Date().toISOString()\n}}];"
      },
      "typeVersion": 2
    },
    {
      "id": "resp1",
