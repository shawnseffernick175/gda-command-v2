    {
      "id": "auth1",
      "name": "Auth Guard",
      "type": "n8n-nodes-base.code",
      "position": [
        220,
        200
      ],
      "parameters": {
        "jsCode": "if (!$env.GDA_API_KEY_2026 || !$env.GDA_DEPLOY_KEY_2026 || !$env.GDA_WEBHOOK_SECRET_2026) throw new Error('2026 auth env vars not set');\nconst headers = $input.first().json.headers || {};\nconst body = $input.first().json.body || {};\nconst auth = headers[\"x-gda-auth\"] || headers[\"x-gda-key\"] || body.auth_key || body.deploy_key || \"\";\nconst validKeys = [$env.GDA_DEPLOY_KEY_2026, $env.GDA_API_KEY_2026, $env.GDA_WEBHOOK_SECRET_2026];\nif (!validKeys.includes(auth)) {\n  const origin = (headers.origin || headers.referer || \"\").toLowerCase();\n  const trusted = [\"gda.csr-llc.tech\",\"n8n.csr-llc.tech\",\"localhost\",\"gdacommand.retool.com\"];\n  if (!trusted.some(o => origin.includes(o))) throw new Error(\"Unauthorized\");\n}\nreturn [{ json: body }];"
      },
      "typeVersion": 2
    },
    {
      "id": "val1",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "position": [
        440,
        200
      ],
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst doc_a_id = body.doc_a_id || body.docAId;\nconst doc_b_id = body.doc_b_id || body.docBId;\nif (!doc_a_id || !doc_b_id) {\n  throw new Error('doc_a_id and doc_b_id are required');\n}\nif (doc_a_id === doc_b_id) {\n  throw new Error('Cannot compare a document with itself');\n}\nreturn [{ json: { doc_a_id, doc_b_id } }];"
      },
      "typeVersion": 2
    },
    {
      "id": "merge1",
      "name": "Merge Docs",
      "type": "n8n-nodes-base.code",
      "position": [
        1140,
        200
      ],
      "parameters": {
        "jsCode": "const docAData = $('Fetch Doc A Chunks').first().json;\nconst docBData = $('Fetch Doc B Chunks').first().json;\nconst ids = $('Validate Input').first().json;\n\nfunction extractText(fetchResult) {\n  const vectors = fetchResult.vectors || {};\n  const sorted = Object.entries(vectors)\n    .sort((a, b) => {\n      const ai = parseInt((a[0].match(/_chunk_(\\d+)$/) || [0,0])[1]);\n      const bi = parseInt((b[0].match(/_chunk_(\\d+)$/) || [0,0])[1]);\n      return ai - bi;\n    });\n  return sorted.map(([id, v]) => (v.metadata || {}).text || '').join('\\n\\n');\n}\n\nconst textA = extractText(docAData);\nconst textB = extractText(docBData);\nconst chunksA = Object.keys(docAData.vectors || {}).length;\nconst chunksB = Object.keys(docBData.vectors || {}).length;\n\nif (chunksA === 0 && chunksB === 0) {\n  throw new Error('Neither document found in knowledge base');\n}\n\nreturn [{ json: {\n  doc_a_id: ids.doc_a_id,\n  doc_b_id: ids.doc_b_id,\n  text_a: textA.substring(0, 12000),\n  text_b: textB.substring(0, 12000),\n  chunks_a: chunksA,\n  chunks_b: chunksB,\n  chars_a: textA.length,\n  chars_b: textB.length\n}}];"
      },
      "typeVersion": 2
    },
    {
      "id": "claude1",
      "name": "Claude Compare",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1380,
        200
      ],
      "parameters": {
        "url": "https://api.anthropic.com/v1/messages",
        "method": "POST",
        "options": {},
        "jsonBody": "={{ JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 2048, messages: [{ role: 'user', content: 'You are analyzing two documents for a defense contractor. Compare them thoroughly.\\n\\n=== DOCUMENT A (ID: ' + $json.doc_a_id + ') ===\\n' + $json.text_a + '\\n\\n=== DOCUMENT B (ID: ' + $json.doc_b_id + ') ===\\n' + $json.text_b + '\\n\\nProvide a structured comparison as JSON with these exact keys:\\n{\\n  \"summary_a\": \"2-3 sentence summary of Document A\",\\n  \"summary_b\": \"2-3 sentence summary of Document B\",\\n  \"key_differences\": [{ \"category\": \"...\", \"doc_a\": \"...\", \"doc_b\": \"...\" }],\\n  \"similarities\": [\"...\"],\\n  \"additions_in_b\": [\"Items in Doc B not in Doc A\"],\\n  \"removals_from_a\": [\"Items in Doc A not in Doc B\"],\\n  \"risk_flags\": [\"Any concerning changes or discrepancies\"],\\n  \"recommendation\": \"Brief actionable recommendation\"\\n}\\nCategories for differences: scope, requirements, terms, dates, personnel, pricing, deliverables, compliance, performance_metrics, evaluation_criteria. Only include categories with actual differences. Respond ONLY with valid JSON, no markdown.' }] }) }}",
        "sendBody": true,
        "sendHeaders": true,
        "specifyBody": "json",
        "authentication": "none",
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{$env.ANTHROPIC_API_KEY}}"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        }
      },
      "credentials": {
        "anthropicApi": {
          "id": "d92MU0tRK7bEGV83",
          "name": "Anthropic account"
        }
      },
      "typeVersion": 4.2
    },
    {
      "id": "fmt1",
      "name": "Format Response",
      "type": "n8n-nodes-base.code",
      "position": [
        1620,
        200
      ],
      "parameters": {
        "jsCode": "const raw = $json.content?.[0]?.text || $json.content || '';\nconst meta = $('Merge Docs').first().json;\nlet comparison = {};\ntry {\n  const match = typeof raw === 'string' ? raw.match(/\\{[\\s\\S]*\\}/) : null;\n  if (match) comparison = JSON.parse(match[0]);\n  else comparison = { summary_a: 'Parse error', summary_b: 'Parse error', key_differences: [], similarities: [], additions_in_b: [], removals_from_a: [], risk_flags: [], recommendation: typeof raw === 'string' ? raw : 'No comparison generated' };\n} catch(e) {\n  comparison = { summary_a: 'Parse error', summary_b: 'Parse error', key_differences: [], similarities: [], additions_in_b: [], removals_from_a: [], risk_flags: [], recommendation: typeof raw === 'string' ? raw.substring(0, 500) : 'Parse failed: ' + e.message };\n}\nreturn [{ json: {\n  status: 'ok',\n  doc_a_id: meta.doc_a_id,\n  doc_b_id: meta.doc_b_id,\n  chunks_a: meta.chunks_a,\n  chunks_b: meta.chunks_b,\n  comparison,\n  timestamp: new Date().toISOString()\n}}];"
      },
      "typeVersion": 2
    },
