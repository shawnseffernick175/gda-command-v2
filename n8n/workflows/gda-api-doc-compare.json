      "parameters": {
        "jsCode": "if (!$env.GDA_API_KEY_2026 || !$env.GDA_DEPLOY_KEY_2026 || !$env.GDA_WEBHOOK_SECRET_2026) throw new Error('2026 auth env vars not set');\nconst headers = $input.first().json.headers || {};\nconst body = $input.first().json.body || {};\nconst auth = headers['x-gda-auth'] || headers['x-gda-key'] || body.auth_key || '';\nif (auth !== $env.GDA_API_KEY_2026) {\n  throw new Error('Unauthorized');\n}\nreturn $input.all();"
      },
      "typeVersion": 2
    },
    {
      "id": "doc-list-extract",
      "name": "Extract Unique Docs",
      "type": "n8n-nodes-base.code",
      "position": [
        660,
        500
      ],
      "parameters": {
        "jsCode": "const vectors = $json.vectors || [];\nconst docMap = {};\nfor (const v of vectors) {\n  const id = v.id || '';\n  const match = id.match(/^(.+)_chunk_(\\d+)$/);\n  if (match) {\n    const docId = match[1];\n    const chunkIdx = parseInt(match[2]);\n    if (!docMap[docId]) docMap[docId] = { id: docId, chunks: 0 };\n    docMap[docId].chunks = Math.max(docMap[docId].chunks, chunkIdx + 1);\n  }\n}\nconst docs = Object.values(docMap).sort((a,b) => b.chunks - a.chunks);\nreturn [{ json: { status: 'ok', documents: docs, total: docs.length } }];"
      },
      "typeVersion": 2
    },
