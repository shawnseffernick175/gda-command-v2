      "parameters": {
        "jsCode": "// Reshape pgvector fetch to Pinecone vectors object shape\nconst pgResponse = $input.first().json;\nconst vecs = (pgResponse.data || {}).vectors || pgResponse.vectors || [];\nconst vectors = {};\nfor (const r of vecs) {\n  vectors[r.id] = {\n    id: r.id,\n    metadata: {\n      text: r.chunk_text || '',\n      document_id: r.document_id || '',\n      chunk_index: r.chunk_index || 0,\n      ...(r.metadata || {})\n    }\n  };\n}\nreturn [{ json: { vectors } }];"
