      {
        "id": "doc-list-extract",
        "name": "Extract Unique Docs",
        "type": "n8n-nodes-base.code",
        "position": [
          660,
          500
        ],
        "parameters": {
          "jsCode": "const vectors = $json.vectors || [];\nconst docMap = {};\nfor (const v of vectors) {\n  const id = v.id || '';\n  const match = id.match(/^(.+)_chunk_(\\d+)$/);\n  if (match) {\n    const docId = match[1];\n    const chunkIdx = parseInt(match[2]);\n    if (!docMap[docId]) docMap[docId] = { id: docId, chunks: 0 };\n    docMap[docId].chunks = Math.max(docMap[docId].chunks, chunkIdx + 1);\n  }\n}\nconst docs = Object.values(docMap).sort((a,b) => b.chunks - a.chunks);\nreturn [{ json: { status: 'ok', documents: docs, total: docs.length } }];"
        },
        "typeVersion": 2
      },
