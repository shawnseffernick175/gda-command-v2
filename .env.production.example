# GDA Command v2 — Production Environment
# Copy to .env.production and fill in values before deploying.

# --- Required ---

# JWT secret for auth tokens (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# --- Optional ---

# Port the frontend is exposed on (default: 80)
APP_PORT=80

# n8n integration (leave blank to use mock fallback)
N8N_BASE_URL=https://n8n.csr-llc.tech
N8N_API_BASE=https://n8n.csr-llc.tech/api/v1
N8N_API_KEY=
N8N_DATABASE_URL=postgresql://n8n:password@n8n-envision-postgres-1:5432/n8n
GDA_WEBHOOK_KEY=

# OpenAI (for AI features: RAG chat, CPARS, RFP shredder, color review)
OPENAI_API_KEY=

# SAM.gov API key (for live federal contract opportunity feeds)
# Get your key: https://sam.gov → Account Details → API Key
SAM_API_KEY=

# Feed sync interval in hours (default: 6, set to 0 to disable)
FEED_SYNC_INTERVAL_HOURS=6

# SMTP Email Notifications (leave blank to disable email delivery)
# Supports any SMTP provider (Gmail, SendGrid, AWS SES, Mailgun, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GDA Command <noreply@yourdomain.com>

# App URL (used in email template links)
APP_URL=https://gda.csr-llc.tech

# --- Server ---
# Port the backend listens on (default: 3001)
# PORT=3001

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# --- Auth ---
# Set to "false" to disable auth middleware (development only)
# AUTH_REQUIRED=true

# --- Feature Flags ---
# Enable/disable qualifying-write dry-run mode
# QUALIFY_WRITES_ENABLED=false

# --- AI ---
# Anthropic API key (optional — alternative LLM provider)
# ANTHROPIC_API_KEY=

# --- GovWin IQ Connector — CAS auth (#561) ---
# GovWin uses Apereo CAS (username + password), NOT OAuth2 client credentials.
GOVWIN_USERNAME=
GOVWIN_PASSWORD=
# Feature flag — set to "true" to enable GovWin routes + cron
GOVWIN_CONNECTOR_V1=false

# --- Color Team Reviews (F-300 Agent Runtime) ---
# Real analysis is provided by the F-300 Agent Runtime. Until it ships, leave
# this false: runs report an honest "unavailable" state and NEVER fabricate
# findings (margins, doctrine scores, exclusion codes). Do not enable without a
# real analysis engine wired in.
COLOR_TEAM_AGENT_RUNTIME_ENABLED=false

# --- Files ---
# Directory for uploaded files (default: ./uploads)
# UPLOAD_DIR=./uploads

# Directory for database backups
# BACKUP_DIR=./backups

# --- Staging Database ---
# Required for docker-compose.prod.yml postgres-staging service.
# Also set as STAGING_DB_PASSWORD GitHub Actions secret for CI.
STAGING_POSTGRES_PASSWORD=CHANGE_ME_STAGING_PASSWORD

# --- Postgres resource tuning (optional) ---
# Defaults in docker-compose.prod.yml are sized for the current 16 GB VPS
# (Postgres: 2 GB ceiling / 2 CPU, shared_buffers 512MB). Override here only if
# the host is resized. Keep shared_buffers ~25% of POSTGRES_MEM_LIMIT.
# For a smaller (~2 GB) box:
#   POSTGRES_MEM_LIMIT=512M
#   POSTGRES_CPUS=1.0
#   POSTGRES_SHARED_BUFFERS=128MB
#   POSTGRES_EFFECTIVE_CACHE_SIZE=384MB
#   POSTGRES_MAINTENANCE_WORK_MEM=96MB
#   POSTGRES_WORK_MEM=8MB

# --- Ingest Feature Flags ---
# Research feeds (nsf/arxiv/nih/sbir/dod_rss) — default OFF (#1132).
# These connectors produce no data any product read-path consumes and only
# generate scheduled no-op jobs + health-panel noise. Set to true to fully
# restore the prior ingestion + health-panel behavior.
RESEARCH_FEEDS_ENABLED=false
# SBIR/STTR cron (sbir.12h) — default OFF.
# api.www.sbir.gov 429-blocks our VPS egress IP. Enable once block lifts.
ENABLE_SBIR_INGEST=false
# Per-feed gates (only apply when RESEARCH_FEEDS_ENABLED=true):
# arXiv — default ON. Set to false to throttle just arXiv (highest-volume feed,
# ~1,600 rows / ~200 per week) while keeping NIH/DoD RSS/SBIR.
ENABLE_ARXIV_INGEST=true
# NSF — default OFF. The NSF Awards API is queried by award start-date within a
# 7-day lookback, which almost never matches, so it reliably returns 0 records
# (idle noise). Re-enable only after the query window is fixed.
ENABLE_NSF_INGEST=false

# --- QA ---
# Timeout for QA health checks in milliseconds (default: 5000)
# QA_CHECK_TIMEOUT_MS=5000
